# .dockerignore — Phase 3 Secure Policy

# ── Block Environment & Credentials ──
.env
.env.yaml
GOOGLE_APPLICATION_CREDENTIALS
service_account.json
credentials.json
*.json
!requirements.json
!package.json

# ── Block Databases ──
*.db
*.sqlite
*.sqlite3
fintech.db
fintech_test.db
finance.db

# ── Block Python Environment & Cache ──
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ── Block logs & Test Results ──
*.txt
!requirements.txt
*.log
final_results.txt
test_results.txt

# ── Block IDEs & System Metadata ──
.vscode/
.idea/
.DS_Store
.git/
.gitignore
.dockerignore
.gcloudignore
Dockerfile
cloudbuild.yaml

# ── Block Agent Workspace ──
.agent/
.gemini/
.brain/
brain/
