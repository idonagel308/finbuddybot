# .gcloudignore — Phase 3 Secure Policy

# ── General Rules ──
.gcloudignore
.git/
.gitignore
.dockerignore

# ── Block Environment & Secrets ──
.env
*.json
GOOGLE_APPLICATION_CREDENTIALS
service_account.json
credentials.json

# ── Block Databases ──
*.db
*.sqlite
*.sqlite3
fintech.db
fintech_test.db
*.db-wal
*.db-shm
*.db.bak

# ── Block Local Python Environment ──
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ── Block Logs & Debug ──
*.txt
!requirements.txt
*.log
debug_db.py
list_models.py

# ── Block IDEs ──
.vscode/
.idea/

# ── Block Agent Workspace ──
.agent/
.gemini/
.brain/
brain/
