# FinTechBot Environment Variables Example
# Rename this file to .env and fill in your actual values

# ── Application Settings ──
ENV=dev  # Set to 'prod' in production
PORT=8000
ALLOWED_USERS=123456789,987654321 # Comma-separated Telegram User IDs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Telegram Configuration ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-ngrok-url.ngrok-free.app/webapp

# ── API Security ──
API_SECRET_KEY=your_strong_api_key_here

# ── AI & Intelligence ──
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ── Database (Firestore) ──
# GCP implicitly uses GOOGLE_APPLICATION_CREDENTIALS if running locally
# For production on Cloud Run, use Service Account with Firestore roles
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
